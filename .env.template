# ======================================
# Express.js-Kusto Environment Configuration Template
# ======================================
# Copy this file to .env and fill in your actual values.
# .env.dev / .env.prod 가 NODE_ENV 에 따라 .env 를 override 합니다.
# Never commit .env file to version control

# ======================================
# COMMON SETTINGS
# ======================================
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# CORS 허용 오리진 — Core 기본 글로벌 미들웨어 정책(defaultGlobalMiddleware:
#   helmet → CORS → cookie → body → 요청 로깅)이 읽어 들입니다.
# JSON 배열 또는 콤마 구분 문자열 둘 다 허용:
#   CORS_WHITELIST=["https://app.example.com","https://admin.example.com"]
#   CORS_WHITELIST=http://127.0.0.1:3000,http://localhost:3000
# 비우면 Origin 헤더가 있는 교차 출처 요청은 차단됩니다(Origin 없는/동일 출처 요청은 허용).
CORS_WHITELIST=http://127.0.0.1:3000,http://localhost:3000

ENABLE_SCHEMA_API=true


# ======================================
# SYSTEM SETTINGS
# ======================================
CORE_APP_BASEPATH=./app
# Express 'trust proxy' — 리버스 프록시(LB/Nginx) 뒤라면 true 로 두어 Express 의 native
# req.ip/req.ips 가 X-Forwarded-* 를 신뢰하도록 합니다.
# 참고: Core 의 clientIp 미들웨어는 이 설정과 무관하게 프록시 헤더(CF-Connecting-IP/
# True-Client-IP/X-Real-IP/X-Forwarded-For)에서 실제 클라이언트 IP 를 추출해 req.ip 를 오버라이드합니다.
TRUST_PROXY=true

# ======================================
# DATABASE URL SETTINGS
# ======================================
# DB URL은 두 가지 방식으로 결정됩니다:
#
# 방식 1) schema.prisma에 url = env("변수명")이 있으면 해당 변수명 사용
#   예: schema.prisma에 url = env("MY_DB_URL") → MY_DB_URL=postgresql://...
#
# 방식 2) schema.prisma에 url이 없으면 폴더명 기반 컨벤션 적용
#   규칙: {FOLDER_NAME}__KUSTO_RDB_URL (폴더명을 UPPER_SNAKE_CASE로 변환 + __KUSTO_RDB_URL)
#   예: src/app/db/default/   → DEFAULT__KUSTO_RDB_URL=postgresql://...
#       src/app/db/analytics/ → ANALYTICS__KUSTO_RDB_URL=postgresql://...
#       src/app/db/myData/    → MY_DATA__KUSTO_RDB_URL=postgresql://...

# DEFAULT__KUSTO_RDB_URL=postgresql://user:password@localhost:5432/mydb

# ======================================
# DOCUMENTATION SETTINGS
# ======================================
# Enable auto-generated API documentation
# Only works in development mode (NODE_ENV !== 'production')
AUTO_DOCS=true
STRICT_STATUS_CODE_CHECK=true

# ======================================
# LOGGING SETTINGS
# ======================================
# 콘솔 로그 레벨은 env 기준 자동 결정됩니다(production→Info, test→Error, 그 외→Debug).
# LOG_LEVEL 로 언제든 override 할 수 있고, 'silent'/'off' 로 전부 끌 수 있습니다.
# (요청 로깅 Footwalk 는 기본 글로벌 미들웨어 정책의 일부입니다.)
# LOG_LEVEL=Debug
# LOG_DIR=./logs
# LOG_MAX_SIZE=20m
# LOG_MAX_FILES=30d
# LOG_FILE_LEVEL=Info
# 민감 키(password/token/authorization/cookie/...)는 자동으로 [REDACTED] 처리됩니다.
# LOG_REDACT=false           # redaction 비활성화
# LOG_REDACT_KEYS=key1,key2  # 추가로 가릴 키
