{
  "name": "kusto-server",
  "version": "0.2.0",
  "description": "Express based custom server for simple backend service",
  "main": "index.js",
  "bin": {
    "kusto": "bin/kusto.js"
  },
  "scripts": {
    "start": "ts-node ./src/index.ts",
    "dev": "npm run generate && nodemon",
    "dev:serve": "nodemon --config nodemon.serve.json",
    "serve": "node dist/server.js",
    "build": "npm run db -- generate --all && npm run generate -- --build && npm run typecheck && webpack --mode production && npm run clean",
    "build:dev": "npm run generate -- --build && webpack --mode development && npm run clean",
    "typecheck": "tsc -p tsconfig.webpack.json --noEmit",
    "clean": "node src/core/scripts/clean-tmp.js",
    "generate": "node src/core/scripts/generate.js",
    "kusto": "ts-node ./src/core/cli/kusto.ts",
    "db": "ts-node ./src/core/scripts/kusto-db-cli.ts",
    "updater:generate": "ts-node ./src/core/updater/generate.ts",
    "updater:check": "ts-node ./src/core/updater/compare.ts",
    "updater:update": "ts-node ./src/core/updater/update.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:ci:serial": "jest --ci --coverage --maxWorkers=1",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:cli": "jest tests/cli"
  },
  "author": "rkdmf0000@gmail.com",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "@types/yauzl": "^2.10.3",
    "archiver": "^7.0.1",
    "body-parser": "^1.20.3",
    "commander": "^14.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.18.3",
    "helmet": "^8.0.0",
    "module-alias": "^2.2.3",
    "multer": "^2.0.1",
    "qs": "^6.15.2",
    "winston": "^3.12.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@electric-sql/pglite": "^0.4.5",
    "@electric-sql/pglite-socket": "^0.1.5",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.28",
    "@types/qs": "^6.14.0",
    "@types/supertest": "^7.2.0",
    "better-sqlite3": "^12.9.0",
    "copy-webpack-plugin": "^14.0.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.1",
    "nodemon": "^3.1.0",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "^1.19.13"
    },
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^4.2.0"
    }
  },
  "_moduleAliases": {
    "@": "./",
    "@app": "./src/app",
    "@core": "./src/core",
    "@lib": "./src/core/lib",
    "@ext": "./src/core/external",
    "@db": "./src/app/db",
    "@tests": "./tests"
  }
}
